{
  "_comment": "Minimal external notifier plugin. Demonstrates the render + notify hook split: render builds a payload without side effects, notify simulates delivery (noop on dry_run). For authoring guidance, see docs/plugin-authoring.md.",
  "api_version": "release-framework.plugin/v1",
  "name": "example-notifier",
  "type": "notifier",
  "plugin_version": "1.0.0",
  "plugin_api_version": 1,
  "framework_version_range": "^0.1.0",
  "entrypoint": {
    "kind": "module",
    "handler": "index.mjs"
  },
  "capabilities": ["render", "notify"],
  "hooks": ["render", "notify"],
  "supported_release_modes": ["framework-managed", "tool-observe"],
  "config_schema": null,
  "required_inputs": [],
  "required_secrets": [],
  "optional_secrets": ["SLACK_WEBHOOK_URL"],
  "permissions": {},
  "supports": {
    "dry_run": true,
    "local": true
  },
  "outputs": ["example-notifier-payload"],
  "trust": {
    "level": "external-allowlisted",
    "allow_in_ci": true
  }
}
