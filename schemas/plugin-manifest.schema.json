{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://relay.dev/schemas/plugin-manifest.schema.json",
  "title": "Relay Plugin Manifest v1",
  "type": "object",
  "required": [
    "api_version",
    "name",
    "type",
    "plugin_version",
    "plugin_api_version",
    "framework_version_range",
    "entrypoint",
    "capabilities",
    "hooks",
    "required_inputs",
    "required_secrets",
    "optional_secrets",
    "permissions",
    "supports",
    "outputs",
    "trust"
  ],
  "properties": {
    "api_version": { "const": "relay.plugin/v1" },
    "name": { "type": "string", "minLength": 1 },
    "type": {
      "type": "string",
      "enum": ["provider", "release_tool", "profile", "artifact_publisher", "notifier", "metadata_enricher"]
    },
    "plugin_version": { "type": "string", "minLength": 1 },
    "plugin_api_version": { "const": 1 },
    "framework_version_range": { "type": "string", "minLength": 1 },
    "entrypoint": {
      "type": "object",
      "required": ["kind", "handler"],
      "properties": {
        "kind": { "type": "string", "enum": ["builtin", "module", "path"] },
        "handler": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "hooks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["normalize", "plan", "observe", "publish", "verify", "enrich", "render", "notify"]
      }
    },
    "supported_release_modes": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "config_schema": { "type": ["string", "null"] },
    "required_inputs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "required_secrets": {
      "type": "array",
      "items": { "type": "string" }
    },
    "optional_secrets": {
      "type": "array",
      "items": { "type": "string" }
    },
    "permissions": {
      "type": "object",
      "additionalProperties": true
    },
    "supports": {
      "type": "object",
      "required": ["dry_run", "local"],
      "properties": {
        "dry_run": { "type": "boolean" },
        "local": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "outputs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "trust": {
      "type": "object",
      "required": ["level", "allow_in_ci"],
      "properties": {
        "level": {
          "type": "string",
          "enum": ["builtin", "first-party-package", "external-allowlisted", "local-path"]
        },
        "allow_in_ci": { "type": "boolean" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
