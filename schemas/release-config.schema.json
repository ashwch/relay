{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://relay.dev/schemas/release-config.schema.json",
  "title": "Relay Config v1",
  "description": "Repository-level configuration for relay. This file chooses how a project defines release completion, versioning, tags, and shared plugin behavior.",
  "examples": [
    {
      "api_version": 1,
      "product_name": "Example Web App",
      "release_profile": "deploy-release",
      "release_mode": "framework-managed",
      "provider_plugin": "builtin:github-actions",
      "profile_plugin": "builtin:deploy-release",
      "tool_plugin": null,
      "artifact_publishers": [],
      "notifiers": [
        {
          "plugin": "builtin:slack-webhook"
        }
      ],
      "metadata_enrichers": [],
      "plugin_allowlist": [],
      "allow_local_plugins": false,
      "stable_branches": [
        "main"
      ],
      "version_source": {
        "type": "date-sha"
      },
      "tag_template": "release-{version}",
      "notes_source": {
        "type": "static"
      },
      "slack": {
        "enabled": true,
        "webhook_secret": "SLACK_WEBHOOK_URL"
      },
      "plugin_config": {}
    },
    {
      "api_version": 1,
      "product_name": "Example Backend",
      "release_profile": "deploy-release",
      "release_mode": "framework-managed",
      "provider_plugin": "builtin:github-actions",
      "profile_plugin": "builtin:deploy-release",
      "tool_plugin": null,
      "artifact_publishers": [],
      "notifiers": [],
      "metadata_enrichers": [],
      "plugin_allowlist": [],
      "allow_local_plugins": false,
      "stable_branches": [
        "main"
      ],
      "version_source": {
        "type": "backend-date-release",
        "counter_source": "github-tag",
        "separator": "."
      },
      "tag_template": "release-{version}",
      "notes_source": {
        "type": "static"
      },
      "plugin_config": {}
    },
    {
      "api_version": 1,
      "product_name": "Relay",
      "release_profile": "npm-package",
      "release_mode": "framework-managed",
      "provider_plugin": "builtin:github-actions",
      "profile_plugin": "builtin:npm-package",
      "tool_plugin": null,
      "artifact_publishers": [
        {
          "plugin": "builtin:npm-registry-verify"
        }
      ],
      "notifiers": [],
      "metadata_enrichers": [],
      "plugin_allowlist": [],
      "allow_local_plugins": false,
      "stable_branches": [
        "main"
      ],
      "version_source": {
        "type": "file",
        "format": "json",
        "path": "package.json",
        "key_path": [
          "version"
        ]
      },
      "tag_template": "v{version}",
      "notes_source": {
        "type": "static"
      },
      "package": {
        "name": "@ashwch/relay",
        "registry_url": "https://registry.npmjs.org"
      },
      "plugin_config": {}
    },
    {
      "api_version": 1,
      "product_name": "Example Service",
      "release_profile": "deploy-release",
      "release_mode": "framework-managed",
      "provider_plugin": "builtin:github-actions",
      "profile_plugin": "builtin:deploy-release",
      "tool_plugin": null,
      "artifact_publishers": [],
      "notifiers": [],
      "metadata_enrichers": [],
      "plugin_allowlist": [],
      "allow_local_plugins": false,
      "stable_branches": [
        "main"
      ],
      "version_source": {
        "type": "conventional-commits",
        "tag_prefix": "v",
        "initial_version": "0.1.0"
      },
      "tag_template": "v{version}",
      "notes_source": {
        "type": "static"
      },
      "plugin_config": {}
    }
  ],
  "type": "object",
  "required": [
    "api_version",
    "product_name",
    "release_profile",
    "release_mode",
    "provider_plugin",
    "profile_plugin",
    "stable_branches",
    "version_source",
    "tag_template",
    "notes_source"
  ],
  "properties": {
    "api_version": {
      "const": 1,
      "description": "Configuration schema major."
    },
    "product_name": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable product or repository name used in release titles and notifications."
    },
    "release_profile": {
      "type": "string",
      "minLength": 1,
      "description": "Stable business-level profile name such as deploy-release, semantic-release, or asset-release."
    },
    "release_mode": {
      "type": "string",
      "enum": [
        "framework-managed",
        "tool-observe",
        "tool-wrap"
      ],
      "description": "Who owns the durable release record: core, an external tool, or a future wrapped tool execution path."
    },
    "provider_plugin": {
      "type": "string",
      "minLength": 1,
      "description": "Default provider plugin ref, usually a built-in such as builtin:github-actions or builtin:circleci."
    },
    "profile_plugin": {
      "type": "string",
      "minLength": 1,
      "description": "Concrete profile plugin implementation for the selected release profile."
    },
    "tool_plugin": {
      "type": [
        "string",
        "null"
      ],
      "description": "Optional release-tool plugin ref for tool-observe or tool-wrap flows."
    },
    "artifact_publishers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/pluginSelection"
      },
      "default": [],
      "description": "Ordered artifact publisher or verifier plugins."
    },
    "notifiers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/pluginSelection"
      },
      "default": [],
      "description": "Ordered notifier plugins."
    },
    "metadata_enrichers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/pluginSelection"
      },
      "default": [],
      "description": "Ordered metadata enrichers that add optional release context."
    },
    "plugin_allowlist": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "description": "Exact npm: or path: plugin refs allowed for this repository."
    },
    "allow_local_plugins": {
      "type": "boolean",
      "default": false,
      "description": "Whether allowlisted path: plugins may load in local or CI contexts."
    },
    "stable_branches": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Branch names that should be treated as stable releases instead of prereleases."
    },
    "version_source": {
      "description": "How this project derives its release version string. Different projects can choose different schemas here.",
      "oneOf": [
        {
          "$ref": "#/$defs/versionSourceDate"
        },
        {
          "$ref": "#/$defs/versionSourceDateSha"
        },
        {
          "$ref": "#/$defs/versionSourceDateTime"
        },
        {
          "$ref": "#/$defs/versionSourceDateCounter"
        },
        {
          "$ref": "#/$defs/versionSourceBackendDateRelease"
        },
        {
          "$ref": "#/$defs/versionSourceTemplate"
        },
        {
          "$ref": "#/$defs/versionSourceExplicit"
        },
        {
          "$ref": "#/$defs/versionSourceFile"
        },
        {
          "$ref": "#/$defs/versionSourceEnv"
        },
        {
          "$ref": "#/$defs/versionSourceGitTag"
        },
        {
          "$ref": "#/$defs/versionSourceConventionalCommits"
        },
        {
          "$ref": "#/$defs/versionSourceChangesets"
        }
      ]
    },
    "tag_template": {
      "type": "string",
      "minLength": 1,
      "description": "Final release tag template. Supported placeholders include {version}, {date}, {counter}, {short_sha}, {sha}, {branch}, and {time}. Prefer {version} when possible. Counter-based schemas should expose either {version} or {counter} so same-day releases stay distinguishable.",
      "examples": [
        "release-{version}",
        "production-{date}-{short_sha}",
        "backend-{date}.{counter}",
        "nightly-{date}.{time}-{short_sha}"
      ]
    },
    "notes_source": {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true,
      "description": "How release notes should be sourced."
    },
    "assets": {
      "type": "object",
      "additionalProperties": true
    },
    "slack": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "webhook_secret": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true,
      "description": "First-party convenience block for Slack webhook notifier settings."
    },
    "package": {
      "type": "object",
      "additionalProperties": true
    },
    "plugin_config": {
      "type": "object",
      "additionalProperties": true,
      "default": {},
      "description": "Plugin-specific configuration keyed by plugin ref."
    }
  },
  "additionalProperties": false,
  "$defs": {
    "pluginSelection": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "object",
          "required": [
            "plugin"
          ],
          "properties": {
            "plugin": {
              "type": "string",
              "minLength": 1
            },
            "options": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "counterSource": {
      "type": "string",
      "enum": [
        "github-tag",
        "explicit"
      ],
      "description": "How a same-day release counter should be resolved."
    },
    "versionSourceDate": {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "const": "date"
        }
      },
      "additionalProperties": false,
      "description": "Plain date versioning, such as 2026.05.22.",
      "examples": [
        {
          "type": "date"
        }
      ]
    },
    "versionSourceDateSha": {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "const": "date-sha"
        }
      },
      "additionalProperties": false,
      "description": "Date plus short SHA versioning, such as 2026.05.22-9f3c1d2.",
      "examples": [
        {
          "type": "date-sha"
        }
      ]
    },
    "versionSourceDateTime": {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "const": "date-time"
        },
        "separator": {
          "type": "string",
          "minLength": 1,
          "default": "."
        },
        "time_precision": {
          "type": "string",
          "enum": [
            "minutes",
            "seconds"
          ],
          "default": "seconds"
        }
      },
      "additionalProperties": false,
      "description": "Date plus UTC time versioning, useful when more than one release can happen in a day and time-based uniqueness is acceptable.",
      "examples": [
        {
          "type": "date-time",
          "separator": ".",
          "time_precision": "seconds"
        }
      ]
    },
    "versionSourceDateCounter": {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "const": "date-counter"
        },
        "counter_source": {
          "$ref": "#/$defs/counterSource",
          "default": "github-tag"
        },
        "counter": {
          "type": "integer",
          "minimum": 1
        },
        "counter_start": {
          "type": "integer",
          "minimum": 1,
          "default": 1
        },
        "padding": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "separator": {
          "type": "string",
          "minLength": 1,
          "default": "."
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "counter_source": {
                "const": "explicit"
              }
            }
          },
          "then": {
            "required": [
              "counter"
            ]
          }
        }
      ],
      "additionalProperties": false,
      "description": "Date plus explicit daily release number, such as 2026.05.22.2.",
      "examples": [
        {
          "type": "date-counter",
          "counter_source": "github-tag",
          "separator": "."
        },
        {
          "type": "date-counter",
          "counter_source": "explicit",
          "counter": 2,
          "separator": "."
        }
      ]
    },
    "versionSourceBackendDateRelease": {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "enum": [
            "backend-date-release",
            "date-release"
          ]
        },
        "counter_source": {
          "$ref": "#/$defs/counterSource",
          "default": "github-tag"
        },
        "counter": {
          "type": "integer",
          "minimum": 1
        },
        "counter_start": {
          "type": "integer",
          "minimum": 1,
          "default": 1
        },
        "padding": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "separator": {
          "type": "string",
          "minLength": 1,
          "default": "."
        },
        "omit_counter_for_first": {
          "type": "boolean",
          "default": true
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "counter_source": {
                "const": "explicit"
              }
            }
          },
          "then": {
            "required": [
              "counter"
            ]
          }
        }
      ],
      "additionalProperties": false,
      "description": "Backend-style date releases where the first release of a day is plain date and later same-day releases add a counter suffix.",
      "examples": [
        {
          "type": "backend-date-release",
          "counter_source": "github-tag",
          "separator": "."
        },
        {
          "type": "backend-date-release",
          "counter_source": "explicit",
          "counter": 3,
          "separator": "."
        }
      ]
    },
    "versionSourceTemplate": {
      "type": "object",
      "required": [
        "type",
        "template"
      ],
      "properties": {
        "type": {
          "const": "template"
        },
        "template": {
          "type": "string",
          "minLength": 1,
          "not": {
            "pattern": "\\{version\\}"
          },
          "description": "Custom version template using concrete fields such as {date}, {counter}, {short_sha}, {sha}, {branch}, or {time}."
        },
        "counter_source": {
          "$ref": "#/$defs/counterSource",
          "default": "github-tag"
        },
        "counter": {
          "type": "integer",
          "minimum": 1
        },
        "counter_start": {
          "type": "integer",
          "minimum": 1,
          "default": 1
        },
        "padding": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "counter_source": {
                "const": "explicit"
              }
            }
          },
          "then": {
            "required": [
              "counter"
            ]
          }
        }
      ],
      "additionalProperties": false,
      "description": "Custom project-specific schema without adding a new framework codepath.",
      "examples": [
        {
          "type": "template",
          "template": "{date}.{counter}-{short_sha}",
          "counter_source": "explicit",
          "counter": 4
        }
      ]
    },
    "versionSourceExplicit": {
      "type": "object",
      "required": [
        "type",
        "value"
      ],
      "properties": {
        "type": {
          "const": "explicit"
        },
        "value": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false,
      "description": "Explicit version value provided by an upstream system or manual process.",
      "examples": [
        {
          "type": "explicit",
          "value": "2026.05.22.7"
        }
      ]
    },
    "versionSourceFile": {
      "type": "object",
      "required": [
        "type",
        "format",
        "path",
        "key_path"
      ],
      "properties": {
        "type": {
          "const": "file"
        },
        "format": {
          "type": "string",
          "enum": [
            "json",
            "yaml",
            "toml"
          ]
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "key_path": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false,
      "description": "Read a static version string from a structured JSON, YAML, or TOML file.",
      "examples": [
        {
          "type": "file",
          "format": "json",
          "path": "package.json",
          "key_path": [
            "version"
          ]
        },
        {
          "type": "file",
          "format": "toml",
          "path": "pyproject.toml",
          "key_path": [
            "project",
            "version"
          ]
        },
        {
          "type": "file",
          "format": "toml",
          "path": "Cargo.toml",
          "key_path": [
            "package",
            "version"
          ]
        },
        {
          "type": "file",
          "format": "yaml",
          "path": ".release-version.yml",
          "key_path": [
            "release",
            "version"
          ]
        }
      ]
    },
    "versionSourceEnv": {
      "type": "object",
      "required": [
        "type",
        "key"
      ],
      "properties": {
        "type": {
          "const": "env"
        },
        "key": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false,
      "description": "Read the version from an environment variable or CI-provided runtime value.",
      "examples": [
        {
          "type": "env",
          "key": "RELEASE_VERSION"
        }
      ]
    },
    "versionSourceGitTag": {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "const": "git-tag"
        },
        "pattern": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false,
      "description": "Read the version from the current tag ref. Optionally extract just the version portion with a regex.",
      "examples": [
        {
          "type": "git-tag"
        },
        {
          "type": "git-tag",
          "pattern": "^v(?<version>.+)$"
        }
      ]
    },
    "versionSourceConventionalCommits": {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "const": "conventional-commits"
        },
        "tag_prefix": {
          "type": "string",
          "default": ""
        },
        "initial_version": {
          "type": "string",
          "minLength": 1,
          "default": "0.1.0"
        },
        "default_increment": {
          "type": "string",
          "enum": [
            "major",
            "minor",
            "patch"
          ],
          "default": "patch"
        }
      },
      "additionalProperties": false,
      "description": "Infer the next semver bump from conventional commit messages since the latest matching tag.",
      "examples": [
        {
          "type": "conventional-commits",
          "tag_prefix": "v",
          "initial_version": "0.1.0",
          "default_increment": "patch"
        }
      ]
    },
    "versionSourceChangesets": {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "const": "changesets"
        },
        "directory": {
          "type": "string",
          "minLength": 1,
          "default": ".changeset"
        },
        "package": {
          "type": "string",
          "minLength": 1
        },
        "tag_prefix": {
          "type": "string",
          "default": ""
        },
        "initial_version": {
          "type": "string",
          "minLength": 1,
          "default": "0.1.0"
        },
        "default_increment": {
          "type": "string",
          "enum": [
            "major",
            "minor",
            "patch"
          ]
        }
      },
      "additionalProperties": false,
      "description": "Infer the next semver bump from pending Changeset files for one package.",
      "examples": [
        {
          "type": "changesets",
          "directory": ".changeset",
          "package": "@example/component-library",
          "tag_prefix": "v",
          "initial_version": "0.1.0"
        }
      ]
    }
  }
}
