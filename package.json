{
  "name": "release-framework",
  "version": "0.1.0",
  "description": "CI-agnostic release finalization framework for teams with mixed release workflows.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "bin": {
    "release-framework": "dist/cli/main.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "action": "npm run build"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "ajv": "^8.17.1",
    "commander": "^14.0.0",
    "semver": "^7.7.2",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/semver": "^7.7.1",
    "eslint": "^9.39.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "vitest": "^4.0.8"
  }
}
