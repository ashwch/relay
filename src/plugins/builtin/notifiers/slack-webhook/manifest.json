{
  "api_version": "relay.plugin/v1",
  "name": "builtin:slack-webhook",
  "type": "notifier",
  "plugin_version": "1.0.0",
  "plugin_api_version": 1,
  "framework_version_range": "^0.1.0",
  "entrypoint": {
    "kind": "builtin",
    "handler": "notifiers.slack_webhook"
  },
  "capabilities": [
    "render",
    "notify"
  ],
  "supported_release_modes": [
    "framework-managed",
    "tool-observe",
    "tool-wrap"
  ],
  "config_schema": null,
  "required_inputs": [],
  "required_secrets": [
    "SLACK_WEBHOOK_URL"
  ],
  "optional_secrets": [],
  "permissions": {
    "github": {},
    "network": [
      "slack-webhook"
    ],
    "id_token": false
  },
  "supports": {
    "dry_run": true,
    "local": true
  },
  "outputs": [
    "slack-payload",
    "delivery-metadata"
  ],
  "trust": {
    "level": "builtin",
    "allow_in_ci": true
  },
  "hooks": [
    "render",
    "notify"
  ]
}
