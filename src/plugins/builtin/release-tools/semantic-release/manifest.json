{
  "api_version": "release-framework.plugin/v1",
  "name": "builtin:semantic-release",
  "type": "release_tool",
  "plugin_version": "1.0.0",
  "plugin_api_version": 1,
  "framework_version_range": "^0.1.0",
  "entrypoint": {
    "kind": "builtin",
    "handler": "release_tools.semantic_release"
  },
  "capabilities": [
    "observe"
  ],
  "supported_release_modes": [
    "tool-observe",
    "tool-wrap"
  ],
  "config_schema": null,
  "required_inputs": [],
  "required_secrets": [],
  "optional_secrets": [],
  "permissions": {
    "github": {
      "contents": "read"
    }
  },
  "supports": {
    "dry_run": true,
    "local": true
  },
  "outputs": [
    "observed-release-record"
  ],
  "trust": {
    "level": "builtin",
    "allow_in_ci": true
  },
  "hooks": [
    "observe"
  ]
}
